{
  "permissions": {
    "allow": [
      "Bash(mkdir -p build)",
      "Bash(cmake ..)",
      "PowerShell(New-Item *)",
      "PowerShell(cmake *)",
      "PowerShell(Get-ChildItem -Recurse | Where-Object { -not $_.PSIsContainer } | Select-Object -First 20)",
      "PowerShell(git submodule *)",
      "PowerShell(Write-Output $\\(Get-Location\\))",
      "PowerShell(Write-Host $PWD)"
    ]
  }
}
